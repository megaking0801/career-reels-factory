# 腳本生成的 LLM 金鑰：二選一即可
# - 填 GROQ_API_KEY：免費，預設（到 https://console.groq.com 申請）
# - 填 ANTHROPIC_API_KEY：繁中品質最佳，用多少付多少
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# 指定 provider：auto / groq / claude（預設 auto：有 Anthropic 用 claude，否則 groq）
SCRIPT_PROVIDER=auto

# 進階（可不動）
# GROQ_MODEL=llama-3.3-70b-versatile
# ANTHROPIC_MODEL=claude-sonnet-4-6
# 中文字型：預設自動偵測（PingFang→STHeiti→Hiragino…）。要指定才填：
# CJK_FONT=/System/Library/Fonts/STHeiti Medium.ttc
# CJK_FONT_NAME=Heiti TC
